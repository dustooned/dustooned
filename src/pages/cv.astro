---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
---

<BaseLayout title="CV" description="Curriculum vitae for Dustin / Dustooned.">
  <article class="content-shell document-page">
    <PageIntro title="CV" description="A text-copy placeholder for the current curriculum vitae." />

    <section class="document-section prose">
      <h2>Dustin / Dustooned</h2>
      <p>Artist, educator, illustrator, animator, and interactive media maker.</p>
      <p><strong>Note:</strong> Replace this placeholder with the current CV text.</p>
    </section>

    <section class="document-section prose">
      <h2>Education</h2>
      <p>Current CV education entries will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Teaching</h2>
      <p>Current teaching appointments, courses, workshops, and academic work will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Selected Projects and Exhibitions</h2>
      <p>Current exhibitions, screenings, publications, talks, and selected projects will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Skills and Tools</h2>
      <p>Current creative, technical, production, and teaching skills will go here.</p>
    </section>
  </article>
</BaseLayout>
