---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
---

<BaseLayout title="Resume" description="Resume for Dustin / Dustooned.">
  <article class="content-shell document-page">
    <PageIntro title="Resume" description="A text-copy placeholder for the current resume." />

    <section class="document-section prose">
      <h2>Dustin / Dustooned</h2>
      <p>Artist, educator, illustrator, animator, and interactive media maker.</p>
      <p><strong>Note:</strong> Replace this placeholder with the current resume text.</p>
    </section>

    <section class="document-section prose">
      <h2>Profile</h2>
      <p>Current short professional summary will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Experience</h2>
      <p>Current work history, teaching experience, production work, and freelance roles will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Selected Work</h2>
      <p>Current selected portfolio, client, publication, animation, and interactive work will go here.</p>
    </section>

    <section class="document-section prose">
      <h2>Skills</h2>
      <p>Current software, creative, technical, and instructional skills will go here.</p>
    </section>
  </article>
</BaseLayout>
