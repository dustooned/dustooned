---
import { withBase } from "../config/content";
---

<section class="newsletter-band" aria-labelledby="newsletter-title">
  <div class="site-shell newsletter-band__inner">
    <div class="newsletter-band__media" aria-hidden="true">
      <img src={withBase("/images/site/newsletter-placeholder.svg")} alt="" loading="lazy" />
    </div>
    <div class="newsletter-band__copy">
      <p class="newsletter-band__eyebrow">Newsletter</p>
      <h2 id="newsletter-title">Subscribe for updates from Dustooned.</h2>
      <p>
        Occasional notes on new motion work, illustration projects, interactive experiments,
        journal posts, and teaching-related updates. No spam ever.
      </p>
      <a class="button-link" href={withBase("/contact")}>Subscription placeholder</a>
    </div>
  </div>
</section>
