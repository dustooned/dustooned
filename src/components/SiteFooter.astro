---
import { navItems, SITE } from "../config/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-shell footer-grid">
    <div>
      <h2>{SITE.title}</h2>
      <p>{SITE.description}</p>
      <p>&copy; {year} Dustin / Dustooned</p>
    </div>
    <nav class="footer-links" aria-label="Footer navigation">
      {
        navItems.map((item) => (
          <a href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener noreferrer" : undefined}>
            {item.label}
            {item.external && <span class="external-indicator" aria-hidden="true">&nearr;</span>}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
