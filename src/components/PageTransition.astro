<div class="page-transition-screen" aria-hidden="true"></div>

<script>
  const transitionDuration = 280;
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const transitionPalette = [
    "#ffffff",
    "#fffaf1",
    "#ffe1d8",
    "#e7f2ef",
    "#f3eadc"
  ];

  function isNormalInternalLink(link) {
    if (!(link instanceof HTMLAnchorElement)) return false;
    if (!link.href || link.target || link.hasAttribute("download")) return false;
    if (link.dataset.noTransition === "true") return false;

    const destination = new URL(link.href);
    const current = new URL(window.location.href);
    const samePageHash =
      destination.origin === current.origin &&
      destination.pathname === current.pathname &&
      destination.search === current.search &&
      destination.hash;

    return destination.origin === current.origin && !samePageHash;
  }

  function paletteColorFor(url) {
    let total = 0;
    for (const character of url) total += character.charCodeAt(0);
    return transitionPalette[total % transitionPalette.length];
  }

  function setTransitionColor(color) {
    document.documentElement.style.setProperty("--page-transition-color", color);
  }

  function leavePage(url) {
    if (prefersReducedMotion.matches) {
      window.location.href = url;
      return;
    }

    const color = paletteColorFor(url);
    setTransitionColor(color);
    sessionStorage.setItem("page-transition-color", color);
    document.documentElement.classList.add("is-page-leaving");
    window.setTimeout(() => {
      window.location.href = url;
    }, transitionDuration);
  }

  window.addEventListener("pageshow", () => {
    const color = sessionStorage.getItem("page-transition-color") || "#ffffff";
    setTransitionColor(color);
    sessionStorage.removeItem("page-transition-color");
    document.documentElement.classList.remove("is-page-leaving");
  });

  document.addEventListener("click", (event) => {
    if (event.defaultPrevented || event.button !== 0) return;
    if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

    const link = event.target instanceof Element ? event.target.closest("a") : null;
    if (!isNormalInternalLink(link)) return;

    event.preventDefault();
    leavePage(link.href);
  });
</script>
