---
import { HERO } from "../config/site";
import { withBase } from "../config/content";

const { eyebrow, title, tagline, primaryCta, secondaryCta, videoSrc, posterImage } = HERO;
const secondaryHref = secondaryCta.href.startsWith("#") ? secondaryCta.href : withBase(secondaryCta.href);
---

<section class="hero">
  <div class="hero__media" aria-hidden="true">
    {
      videoSrc ? (
        <video class="hero__video" autoplay muted loop playsinline poster={posterImage || undefined}>
          <source src={videoSrc} />
        </video>
      ) : (
        <div class="hero__placeholder"></div>
      )
    }
    <div class="hero__overlay"></div>
  </div>
  <div class="hero__content">
    <p class="hero__eyebrow">{eyebrow}</p>
    <h1 class="hero__title">{title}</h1>
    <p class="hero__tagline">{tagline}</p>
    <div class="hero__actions">
      <a class="button-link button-link--light" href={withBase(primaryCta.href)}>{primaryCta.label}</a>
      <a class="button-link button-link--ghost" href={secondaryHref}>{secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: min(80vh, 640px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: calc(var(--space-7) * -1);
    margin-bottom: var(--space-7);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__video,
  .hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__placeholder {
    background: linear-gradient(120deg, var(--color-accent), var(--color-secondary), var(--color-accent));
    background-size: 220% 220%;
    animation: hero-drift 16s ease-in-out infinite;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 8, 6, 0.12) 0%, rgba(10, 8, 6, 0.62) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-4);
    width: min(100% - 2rem, var(--site-max-width));
    margin-inline: auto;
    padding-block: var(--space-8) var(--space-7);
    color: #fff;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: #fff;
    opacity: 0.85;
  }

  .hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--display-weight);
    font-size: clamp(2.4rem, 4vw + 1rem, 5rem);
    line-height: 0.98;
    color: #fff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.4);
    max-width: 20ch;
  }

  .hero__tagline {
    margin: 0;
    font-size: var(--step-1);
    max-width: 56ch;
    color: rgba(255, 255, 255, 0.92);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  @keyframes hero-drift {
    0%,
    100% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__placeholder {
      animation: none;
    }
  }

  @media (min-width: 768px) {
    .hero {
      margin-top: calc(var(--space-8) * -1);
    }
  }
</style>
