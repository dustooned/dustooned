---
import { withBase } from "../config/content";

type Props = {
  title: string;
  href?: string;
  thumbnail: string;
  description?: string;
  year?: string;
  role?: string;
  tags?: string[];
  isMotion?: boolean;
  videoUrl?: string;
  episodes?: { label: string; videoUrl: string }[];
  gallery?: string[];
  isImageLightbox?: boolean;
  image?: string;
  external?: boolean;
};

const {
  title,
  href,
  thumbnail,
  description,
  year,
  role,
  tags = [],
  isMotion = false,
  videoUrl,
  episodes = [],
  gallery = [],
  isImageLightbox = false,
  image,
  external = false
} = Astro.props;
---

{
  isMotion ? (
    <button
      class="card project-card"
      type="button"
      data-motion-trigger
      data-title={title}
      data-description={description}
      data-year={year}
      data-role={role}
      data-tags={tags.join(", ")}
      data-video-url={videoUrl}
      data-episodes={episodes.length > 1 ? JSON.stringify(episodes) : undefined}
      data-gallery={gallery.length > 0 ? JSON.stringify(gallery.map((g) => withBase(g))) : undefined}
    >
      <span class="card__media">
        <img src={withBase(thumbnail)} alt={`${title} thumbnail`} loading="lazy" />
      </span>
      <span class="card__body">
        <span class="card__meta">{[year, role].filter(Boolean).join(" / ")}</span>
        <span class="card__title">{title}</span>
        {description && <span class="card__description">{description}</span>}
      </span>
    </button>
  ) : isImageLightbox ? (
    <button
      class="card project-card"
      type="button"
      data-image-trigger
      data-title={title}
      data-description={description}
      data-year={year}
      data-role={role}
      data-tags={tags.join(", ")}
      data-image={withBase(image || thumbnail)}
    >
      <span class="card__media">
        <img src={withBase(thumbnail)} alt={`${title} thumbnail`} loading="lazy" />
      </span>
      <span class="card__body">
        <span class="card__meta">{[year, role].filter(Boolean).join(" / ")}</span>
        <span class="card__title">{title}</span>
        {description && <span class="card__description">{description}</span>}
      </span>
    </button>
  ) : (
    <a
      class="card project-card"
      href={withBase(href)}
      target={external ? "_blank" : undefined}
      rel={external ? "noopener noreferrer" : undefined}
    >
      <span class="card__media">
        <img src={withBase(thumbnail)} alt={`${title} thumbnail`} loading="lazy" />
      </span>
      <span class="card__body">
        <span class="card__meta">{[year, role].filter(Boolean).join(" / ")}</span>
        <span class="card__title">
          {title}
          {external && <span class="external-indicator" aria-hidden="true">&nearr;</span>}
        </span>
        {description && <span class="card__description">{description}</span>}
      </span>
    </a>
  )
}
