---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/TagList.astro";
import { withBase } from "../config/content";

type Props = {
  entry: CollectionEntry<"journal">;
};

const { entry } = Astro.props;
const data = entry.data;
const formattedDate = data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC"
});
---

<BaseLayout title={data.title} description={data.excerpt}>
  <article class="content-shell">
    <header class="page-intro">
      <p>{formattedDate}</p>
      <h1>{data.title}</h1>
      <p>{data.excerpt}</p>
      <TagList tags={data.tags} />
    </header>

    {data.thumbnail && <img class="project-hero__image" src={withBase(data.thumbnail)} alt={data.title} />}

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
